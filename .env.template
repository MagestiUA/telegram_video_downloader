# Telegram application ID (отримується в https://my.telegram.org)
API_ID=YOUR_TELEGRAM_API_ID

# Telegram application hash (той самий акаунт, що і API_ID)
API_HASH=YOUR_TELEGRAM_API_HASH

# Bot token, виданий @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Google Gemini API key (опційно, якщо бот використовує LLM)
# Отримується в Google AI Studio
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Абсолютний шлях на сервері, куди бот буде завантажувати файли
# Має бути доступний на запис і примонтований у Docker (якщо використовується)
DOWNLOAD_PATH=/absolute/path/to/downloads

# Список Telegram user_id, яким дозволено користуватись ботом
# Через кому, без пробілів
ALLOWED_USERS=123456789,987654321